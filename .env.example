# Trishula — environment template. Copy to .env and fill in. NEVER commit .env.
# On the droplet, real values live in /home/globalbot/.env.

# --- Delta Exchange India ---
# testnet | india_live  (label only; the base URL drives the actual endpoint)
DELTA_ENV=testnet
# Use India endpoints. Point this at the testnet host for paper/integration.
DELTA_BASE_URL=https://api.india.delta.exchange
DELTA_WS_URL=wss://socket.india.delta.exchange
DELTA_API_KEY=
DELTA_API_SECRET=

# --- Safety switches (both required for live; defaults keep paper-mode hard) ---
PAPER_MODE=true
LIVE_TRADING_AUTHORIZED=false

# --- Advisory / reporting ---
GEMINI_API_KEY=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Risk knobs ---
MAX_PCT_PER_POSITION=0.10
